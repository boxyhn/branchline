      <Color x:Key="Color.GlassBorder">#26FFFFFF</Color>
      <Color x:Key="Color.GlassHighlight">#34FFFFFF</Color>
      <Color x:Key="Color.GlassSelection">#16FFFFFF</Color>
      <Color x:Key="Color.Selection">#12FFFFFF</Color>
      <Color x:Key="Color.SelectionStrong">#24FFFFFF</Color>
      <Color x:Key="Color.Status.Modified">#FFE3B341</Color>
      <Color x:Key="Color.Status.TypeChanged">#FFB5A1FF</Color>
      <Color x:Key="Color.Status.Added">#FF56D364</Color>
      <Color x:Key="Color.Status.Deleted">#FFFF7B72</Color>
      <Color x:Key="Color.Status.Renamed">#FF8B98FF</Color>
      <Color x:Key="Color.Status.Copied">#FFDDBB55</Color>
      <Color x:Key="Color.Status.Untracked">#FF7CB7C4</Color>
      <Color x:Key="Color.Status.Conflict">#FFFFA657</Color>
