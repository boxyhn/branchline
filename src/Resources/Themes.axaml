      <Color x:Key="Color.FlatButton.FloatingBorder">#FF4A505A</Color>
      <Color x:Key="Color.FG1">#FFF2F3F5</Color>
      <Color x:Key="Color.FG2">#FFA6ABB3</Color>
      <Color x:Key="Color.Diff.EmptyBG">#3C000000</Color>
      <Color x:Key="Color.Diff.AddedBG">#C03A5C3F</Color>
