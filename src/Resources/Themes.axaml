      <Color x:Key="Color.GlassTop">#D923262C</Color>
      <Color x:Key="Color.GlassMid">#D923262C</Color>
      <Color x:Key="Color.GlassBottom">#D923262C</Color>
      <Color x:Key="Color.GlassControlTop">#B82B2F37</Color>
      <Color x:Key="Color.GlassControlBottom">#B82B2F37</Color>
      <Color x:Key="Color.GlassSidebarTop">#E61A1D22</Color>
      <Color x:Key="Color.GlassSidebarBottom">#E61A1D22</Color>
      <Color x:Key="Color.GlassOverlayTop">#F42A2E35</Color>
