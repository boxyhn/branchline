      <Color x:Key="Color.Border2">#FFD4D7DC</Color>
      <Color x:Key="Color.FlatButton.Background">#FFF7F7F8</Color>
      <Color x:Key="Color.FlatButton.BackgroundHovered">#FFEDEFF2</Color>
      <Color x:Key="Color.FlatButton.BackgroundPressed">#FFE1E4E8</Color>
      <Color x:Key="Color.FlatButton.FloatingBorder">#FFC6CAD1</Color>
      <Color x:Key="Color.FG1">#FF202226</Color>
      <Color x:Key="Color.FG2">#FF666B73</Color>
      <Color x:Key="Color.Diff.EmptyBG">#10000000</Color>
      <Color x:Key="Color.Diff.AddedBG">#80BFE6C1</Color>
      <Color x:Key="Color.Diff.DeletedBG">#80FF9797</Color>
