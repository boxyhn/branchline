      <Color x:Key="Color.Panel">#FF16191E</Color>
      <Color x:Key="Color.PanelRaised">#FF1C1F25</Color>
      <Color x:Key="Color.Input">#FF181B20</Color>
      <Color x:Key="Color.Hover">#14FFFFFF</Color>
      <Color x:Key="Color.Pressed">#24FFFFFF</Color>
      <Color x:Key="Color.Separator">#FF2A2E35</Color>
      <Color x:Key="Color.Badge">#FF30343C</Color>
      <Color x:Key="Color.BadgeFG">#FFF4F5F7</Color>
