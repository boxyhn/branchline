    <ResourceDictionary x:Key="Dark">
      <Color x:Key="Color.Window">#FF15171B</Color>
      <Color x:Key="Color.WindowBorder">#FF353941</Color>
      <Color x:Key="Color.TitleBar">#E61B1D22</Color>
