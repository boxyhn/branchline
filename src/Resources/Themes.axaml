      <Color x:Key="Color.GlassSelection">#0F000000</Color>
      <Color x:Key="Color.Selection">#0A000000</Color>
      <Color x:Key="Color.SelectionStrong">#14000000</Color>
      <Color x:Key="Color.Status.Modified">#FF9A6700</Color>
      <Color x:Key="Color.Status.TypeChanged">#FF7A5AF8</Color>
      <Color x:Key="Color.Status.Added">#FF218739</Color>
      <Color x:Key="Color.Status.Deleted">#FFD1242F</Color>
      <Color x:Key="Color.Status.Renamed">#FF5965D8</Color>
      <Color x:Key="Color.Status.Copied">#FF8A6A00</Color>
      <Color x:Key="Color.Status.Untracked">#FF58727F</Color>
      <Color x:Key="Color.Status.Conflict">#FFC2410C</Color>
