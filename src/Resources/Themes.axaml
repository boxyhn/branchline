      <Color x:Key="Color.HistoryBG">#FFF7F7F8</Color>
      <Color x:Key="Color.GlassTint">#FFF2F3F5</Color>
      <Color x:Key="Color.GlassFallback">#F4EAEBED</Color>
      <Color x:Key="Color.GlassTop">#E8FFFFFF</Color>
      <Color x:Key="Color.GlassMid">#E8FFFFFF</Color>
      <Color x:Key="Color.GlassBottom">#E8FFFFFF</Color>
      <Color x:Key="Color.GlassControlTop">#B8FFFFFF</Color>
      <Color x:Key="Color.GlassControlBottom">#B8FFFFFF</Color>
      <Color x:Key="Color.GlassSidebarTop">#E6F4F5F7</Color>
