<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:m="using:SourceGit.Models"
             xmlns:vm="using:SourceGit.ViewModels"
             xmlns:v="using:SourceGit.Views"
             xmlns:c="using:SourceGit.Converters"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="SourceGit.Views.Histories"
             x:DataType="vm:Histories"
             x:Name="ThisControl">
  <v:HistoriesLayout UseHorizontal="{Binding Source={x:Static vm:Preferences.Instance}, Path=UseTwoColumnsLayoutInHistories}">
    <v:HistoriesLayout.RowDefinitions>
      <RowDefinition Height="{Binding TopArea, Mode=TwoWay}" MinHeight="100"/>
      <RowDefinition Height="3"/>
      <RowDefinition Height="{Binding BottomArea, Mode=TwoWay}" MinHeight="28"/>
    </v:HistoriesLayout.RowDefinitions>

    <v:HistoriesLayout.ColumnDefinitions>
      <ColumnDefinition Width="{Binding LeftArea, Mode=TwoWay}" MinWidth="100"/>
      <ColumnDefinition Width="3"/>
      <ColumnDefinition Width="{Binding RightArea, Mode=TwoWay}" MinWidth="100"/>
    </v:HistoriesLayout.ColumnDefinitions>

    <Grid Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3">
      <v:HistoriesCommitList x:Name="CommitListContainer"
                             Classes="static_scrollbar"
                             ScrollViewer.AllowAutoHide="False"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             Background="Transparent"
                             ItemsSource="{Binding Commits, Mode=OneWay}"
                             TotalCommits="{Binding Commits.Count, Mode=OneWay}"
                             SelectedCommits="{Binding SelectedCommits, Mode=TwoWay}"
                             ColumnHeaderHeight="30"
                             RowHeight="32"
                             LayoutUpdated="OnCommitListLayoutUpdated"
                             ContextRequested="OnCommitListContextRequested"
                             DoubleTapped="OnCommitListDoubleTapped">
        <v:HistoriesCommitList.Resources>
          <SolidColorBrush x:Key="DataGridRowHoveredBackgroundColor" Color="{DynamicResource Color.HistoryRowHover}"/>
          <SolidColorBrush x:Key="DataGridRowSelectedBackgroundBrush" Color="{DynamicResource Color.HistoryRowSelected}"/>
          <SolidColorBrush x:Key="DataGridRowSelectedHoveredBackgroundBrush" Color="{DynamicResource Color.HistoryRowSelected}"/>
          <SolidColorBrush x:Key="DataGridRowSelectedUnfocusedBackgroundBrush" Color="{DynamicResource Color.HistoryRowSelected}"/>
          <SolidColorBrush x:Key="DataGridRowSelectedHoveredUnfocusedBackgroundBrush" Color="{DynamicResource Color.HistoryRowSelected}"/>
          <x:Double x:Key="DataGridRowSelectedBackgroundOpacity">1</x:Double>
          <x:Double x:Key="DataGridRowSelectedHoveredBackgroundOpacity">1</x:Double>
          <x:Double x:Key="DataGridRowSelectedUnfocusedBackgroundOpacity">1</x:Double>
          <x:Double x:Key="DataGridRowSelectedHoveredUnfocusedBackgroundOpacity">1</x:Double>
        </v:HistoriesCommitList.Resources>
        <DataGrid.Styles>
          <Style Selector="DataGridRow:pointerover">
            <Setter Property="Background" Value="{DynamicResource Brush.HistoryRowHover}"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
          </Style>

          <Style Selector="DataGridRow:pointerover /template/ Rectangle#BackgroundRectangle">
            <Setter Property="Fill" Value="{DynamicResource Brush.HistoryRowHover}"/>
            <Setter Property="Opacity" Value="1"/>
          </Style>

          <Style Selector="DataGridRow:selected">
            <Setter Property="Background" Value="{DynamicResource Brush.HistoryRowSelected}"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
          </Style>

          <Style Selector="DataGridRow:selected /template/ Rectangle#BackgroundRectangle">
            <Setter Property="Fill" Value="{DynamicResource Brush.HistoryRowSelected}"/>
            <Setter Property="Opacity" Value="1"/>
          </Style>

          <Style Selector="DataGridRow:selected:focus /template/ Rectangle#BackgroundRectangle">
            <Setter Property="Fill" Value="{DynamicResource Brush.HistoryRowSelected}"/>
            <Setter Property="Opacity" Value="1"/>
          </Style>

          <Style Selector="DataGridRow:selected:pointerover">
            <Setter Property="Background" Value="{DynamicResource Brush.HistoryRowSelected}"/>
          </Style>

          <Style Selector="DataGridRow:selected:pointerover /template/ Rectangle#BackgroundRectangle">
            <Setter Property="Fill" Value="{DynamicResource Brush.HistoryRowSelected}"/>
            <Setter Property="Opacity" Value="1"/>
          </Style>

          <Style Selector="DataGridRow:selected DataGridCell.history_detail_cell">
            <Setter Property="Background" Value="{DynamicResource Brush.HistoryDetailSelected}"/>
          </Style>

          <Style Selector="DataGrid.static_scrollbar">
            <Style Selector="^ /template/ DataGridRowsPresenter#PART_RowsPresenter">
              <Setter Property="Grid.RowSpan" Value="1" />
              <Setter Property="Grid.ColumnSpan" Value="2" />
              <Setter Property="Background" Value="{DynamicResource Brush.HistoryBG}"/>
            </Style>
            <Style Selector="^ /template/ DataGridColumnHeadersPresenter#PART_ColumnHeadersPresenter">
              <Setter Property="Grid.Column" Value="0" />
              <Setter Property="Background" Value="{DynamicResource Brush.HistoryHeader}" />
            </Style>
            <Style Selector="^ /template/ Rectangle#PART_ColumnHeadersAndRowsSeparator">
              <Setter Property="Fill" Value="{DynamicResource Brush.Border0}"/>
              <Setter Property="Height" Value="0.65"/>
            </Style>
            <Style Selector="^ /template/ ScrollBar">
              <Setter Property="Background" Value="{DynamicResource Brush.Contents}"/>
            </Style>
          </Style>

          <Style Selector="DataGridColumnHeader">
            <Setter Property="MinHeight" Value="26"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
              <ControlTemplate>
                <Border x:Name="HeaderBorder"
                        Background="{TemplateBinding Background}"
                        BorderThickness="0"
                        CornerRadius="0">
                  <Grid>
                    <ContentPresenter x:Name="PART_ContentPresenter"
                                      Content="{TemplateBinding Content}"
                                      ContentTemplate="{TemplateBinding ContentTemplate}" />
                  </Grid>
                </Border>
              </ControlTemplate>
            </Setter>
          </Style>

          <Style Selector="DataGridCell">
            <Setter Property="Template">
              <ControlTemplate>
                <Grid x:Name="PART_CellRoot" Background="{TemplateBinding Background}">
                  <ContentPresenter Margin="0"
                                    HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                    VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                    Content="{TemplateBinding Content}"
                                    ContentTemplate="{TemplateBinding ContentTemplate}"
                                    Foreground="{TemplateBinding Foreground}" />
                </Grid>
              </ControlTemplate>
            </Setter>
          </Style>
        </DataGrid.Styles>

        <DataGrid.Columns>
          <DataGridTemplateColumn Width="155" MinWidth="110" IsReadOnly="True">
            <DataGridTemplateColumn.Header>
              <TextBlock Classes="table_header"
                         Text="BRANCH / TAG"
                         HorizontalAlignment="Center"/>
            </DataGridTemplateColumn.Header>

            <DataGridTemplateColumn.CellTemplate>
              <DataTemplate DataType="m:Commit">
                <Border Margin="5,0,8,0" ClipToBounds="True">
                  <v:CommitRefsPresenter ClipToBounds="True"
                                         Background="{DynamicResource Brush.Contents}"
                                         Foreground="{DynamicResource Brush.FG1}"
                                         ShowTags="{Binding Source={x:Static vm:Preferences.Instance}, Path=ShowTagsInGraph}"
                                         FontSize="13"
                                         HorizontalAlignment="Stretch"
                                         VerticalAlignment="Center"
                                         UseGraphColor="{Binding IsHighlightedInGraph, Mode=OneWay}"
                                         UseCompactBranchNames="{Binding Source={x:Static vm:Preferences.Instance}, Path=UseCompactBranchNamesInGraph}"/>
                </Border>
              </DataTemplate>
            </DataGridTemplateColumn.CellTemplate>
          </DataGridTemplateColumn>

          <DataGridTemplateColumn Width="92" MinWidth="70" IsReadOnly="True">
            <DataGridTemplateColumn.Header>
              <TextBlock Classes="table_header" Text="GRAPH" HorizontalAlignment="Center"/>
            </DataGridTemplateColumn.Header>

            <DataGridTemplateColumn.CellTemplate>
              <DataTemplate DataType="m:Commit">
                <Border Background="Transparent" IsHitTestVisible="False"/>
              </DataTemplate>
            </DataGridTemplateColumn.CellTemplate>
          </DataGridTemplateColumn>

          <DataGridTemplateColumn Width="*" MinWidth="160" IsReadOnly="True" CellStyleClasses="history_detail_cell">
            <DataGridTemplateColumn.Header>
              <TextBlock Classes="table_header" Text="COMMIT MESSAGE" Margin="8,0,0,0" HorizontalAlignment="Left"/>
            </DataGridTemplateColumn.Header>

            <DataGridTemplateColumn.CellTemplate>
              <DataTemplate DataType="m:Commit">
                <Border ClipToBounds="True" Background="Transparent">
                  <Grid ColumnDefinitions="3,*" ClipToBounds="True">
                    <v:CommitLaneIndicator Grid.Column="0" VerticalAlignment="Stretch" IsHitTestVisible="False"/>

                    <Grid Grid.Column="1" ColumnDefinitions="Auto,*" Margin="9,0,4,0" ClipToBounds="True">
                      <v:BisectStateIndicator Grid.Column="0"
                                              Background="{DynamicResource Brush.Contents}"
                                              Foreground="{DynamicResource Brush.FG1}"
                                              Bisect="{Binding $parent[v:Histories].Bisect}"
                                              VerticalAlignment="Center"/>

                      <v:CommitSubjectPresenter Grid.Column="1"
                                              Height="32"
                                              FontSize="14"
                                              FontFamily="{DynamicResource Fonts.Default}"
                                              CodeFontFamily="{DynamicResource Fonts.Monospace}"
                                              InlineCodeBackground="{DynamicResource Brush.InlineCode}"
                                              InlineCodeForeground="{DynamicResource Brush.InlineCodeFG}"
                                              Foreground="{DynamicResource Brush.FG1}"
                                              LinkForeground="{DynamicResource Brush.Link}"
                                              Subject="{Binding Subject}"
                                              IssueTrackers="{Binding $parent[v:Histories].IssueTrackers}"
                                              FontWeight="{Binding IsCurrentHead, Converter={x:Static c:BoolConverters.IsBoldToFontWeight}}"
                                              Opacity="{Binding IsMerged, Converter={x:Static c:BoolConverters.IsMergedToOpacity}}"/>
                    </Grid>
                  </Grid>
                </Border>
              </DataTemplate>
            </DataGridTemplateColumn.CellTemplate>
          </DataGridTemplateColumn>

          <DataGridTemplateColumn Width="96" MinWidth="76" IsReadOnly="True" IsVisible="{Binding IsAuthorColumnVisible, Mode=OneWay}" CellStyleClasses="history_detail_cell">
            <DataGridTemplateColumn.Header>
              <TextBlock Classes="table_header" Text="{DynamicResource Text.Histories.Header.Author}" Margin="8,0,0,0" HorizontalAlignment="Left"/>
            </DataGridTemplateColumn.Header>

            <DataGridTemplateColumn.CellTemplate>
              <DataTemplate DataType="m:Commit">
                <Grid ColumnDefinitions="28,*" Background="Transparent">
                  <v:Avatar Grid.Column="0"
                            Width="22" Height="22"
                            Margin="3,0,0,0"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            User="{Binding Author}"
                            Opacity="{Binding IsMerged, Converter={x:Static c:BoolConverters.IsMergedToOpacity}}"
                            IsHitTestVisible="False"/>

                  <Border Grid.Column="1" Padding="8,0" ClipToBounds="True">
                    <TextBlock Text="{Binding Author.Name}"
                               FontWeight="{Binding IsCurrentHead, Converter={x:Static c:BoolConverters.IsBoldToFontWeight}}"
                               Opacity="{Binding IsMerged, Converter={x:Static c:BoolConverters.IsMergedToOpacity}}"
                               HorizontalAlignment="Left"/>
                  </Border>
                </Grid>
              </DataTemplate>
            </DataGridTemplateColumn.CellTemplate>
          </DataGridTemplateColumn>

          <DataGridTemplateColumn MinWidth="100" IsReadOnly="True" IsVisible="{Binding IsSHAColumnVisible, Mode=OneWay}" CellStyleClasses="history_detail_cell">
            <DataGridTemplateColumn.Header>
              <TextBlock Classes="table_header" Text="{DynamicResource Text.Histories.Header.SHA}" Margin="8,0,0,0" HorizontalAlignment="Left"/>
            </DataGridTemplateColumn.Header>

            <DataGridTemplateColumn.CellTemplate>
              <DataTemplate DataType="m:Commit">
                <Border Padding="8,0,0,0" Background="Transparent" ClipToBounds="True">
                  <TextBlock Text="{Binding SHA, Converter={x:Static c:StringConverters.ToShortSHA}}"
                             ToolTip.Tip="{Binding SHA}"
                             Cursor="Hand"
                             PointerPressed="OnSHAPointerPressed"
                             FontFamily="{DynamicResource Fonts.Monospace}"
                             FontWeight="{Binding IsCurrentHead, Converter={x:Static c:BoolConverters.IsBoldToFontWeight}}"
                             Opacity="{Binding IsMerged, Converter={x:Static c:BoolConverters.IsMergedToOpacity}}"/>
                </Border>
              </DataTemplate>
            </DataGridTemplateColumn.CellTemplate>
          </DataGridTemplateColumn>

          <DataGridTemplateColumn Width="124" MinWidth="108" IsReadOnly="True" IsVisible="{Binding IsAuthorTimeColumnVisible, Mode=OneWay}" CellStyleClasses="history_detail_cell">
            <DataGridTemplateColumn.Header>
              <TextBlock Classes="table_header" Text="{DynamicResource Text.Histories.Header.AuthorTime}" Margin="8,0,0,0" HorizontalAlignment="Left"/>
            </DataGridTemplateColumn.Header>

            <DataGridTemplateColumn.CellTemplate>
              <DataTemplate DataType="m:Commit">
                <Border Padding="4,0" Background="Transparent" ClipToBounds="True">
                  <v:CommitTimeTextBlock FontFeatures="+tnum"
                                         FontSize="11"
                                         Foreground="{DynamicResource Brush.FG2}"
                                         FontWeight="{Binding IsCurrentHead, Converter={x:Static c:BoolConverters.IsBoldToFontWeight}}"
                                         Opacity="{Binding IsMerged, Converter={x:Static c:BoolConverters.IsMergedToOpacity}}"
                                         Timestamp="{Binding AuthorTime, Mode=OneWay}"
                                         ShowAsDateTime="False"/>
                </Border>
              </DataTemplate>
            </DataGridTemplateColumn.CellTemplate>
          </DataGridTemplateColumn>

          <DataGridTemplateColumn Width="124" MinWidth="108" IsReadOnly="True" IsVisible="{Binding IsCommitTimeColumnVisible, Mode=OneWay}" CellStyleClasses="history_detail_cell">
            <DataGridTemplateColumn.Header>
              <TextBlock Classes="table_header" Text="{DynamicResource Text.Histories.Header.CommitTime}" Margin="8,0,0,0" HorizontalAlignment="Left"/>
            </DataGridTemplateColumn.Header>

            <DataGridTemplateColumn.CellTemplate>
              <DataTemplate DataType="m:Commit">
                <Border Padding="4,0" Background="Transparent" ClipToBounds="True">
                  <v:CommitTimeTextBlock FontWeight="{Binding IsCurrentHead, Converter={x:Static c:BoolConverters.IsBoldToFontWeight}}"
                                         FontFeatures="+tnum"
                                         FontSize="11"
                                         Foreground="{DynamicResource Brush.FG2}"
                                         Opacity="{Binding IsMerged, Converter={x:Static c:BoolConverters.IsMergedToOpacity}}"
                                         Timestamp="{Binding CommitterTime, Mode=OneWay}"
                                         ShowAsDateTime="False"/>
                </Border>
              </DataTemplate>
            </DataGridTemplateColumn.CellTemplate>
          </DataGridTemplateColumn>
        </DataGrid.Columns>
      </v:HistoriesCommitList>

      <Border Background="Transparent"
              Height="30"
              HorizontalAlignment="Stretch" VerticalAlignment="Top"
              PointerMoved="OnCommitListHeaderPointerMoved"
              PointerPressed="OnCommitListHeaderPointerPressed"
              PointerReleased="OnCommitListHeaderPointerReleased"
              PointerCaptureLost="OnCommitListHeaderPointerCaptureLost"
              ContextRequested="OnCommitListHeaderContextRequested"/>

      <v:CommitGraph x:Name="CommitGraph"
                     Width="92"
                     Margin="155,30,0,0"
                     Graph="{Binding Graph}"
                     DotBrush="{DynamicResource Brush.HistoryBG}"
                     RowBrush="{DynamicResource Brush.HistoryGraphRow}"
                     HorizontalAlignment="Left" VerticalAlignment="Stretch"
                     PointerMoved="OnCommitGraphPointerMoved"
                     PointerExited="OnCommitGraphPointerExited"
                     PointerPressed="OnCommitGraphPointerPressed"
                     ToolTip.ShowDelay="100"
                     ToolTip.Placement="Pointer"
                     ClipToBounds="True"
                     Loaded="OnCommitGraphLoaded"/>

      <Border Width="28" Height="28"
              Margin="0,0,16,8"
              CornerRadius="14"
              Background="{DynamicResource Brush.Popup}"
              HorizontalAlignment="Right" VerticalAlignment="Bottom"
              Effect="drop-shadow(0 0 8 #80000000)"
              PointerPressed="OnScrollToTopPointerPressed"
              IsVisible="{Binding $parent[v:Histories].IsScrollToTopVisible}">
        <Path Width="12" Height="12"
              Data="{StaticResource Icons.ScrollToTop}"
              Fill="{DynamicResource Brush.FG1}"
              Opacity=".8"/>
      </Border>

      <v:LoadingIcon Width="48" Height="48" HorizontalAlignment="Center" VerticalAlignment="Center" IsVisible="{Binding IsLoading}"/>

      <Border Background="{DynamicResource Brush.Contents}"
              IsVisible="{Binding ActiveDiffContext, Converter={x:Static ObjectConverters.IsNotNull}}">
        <ContentControl Content="{Binding ActiveDiffContext}">
          <ContentControl.DataTemplates>
            <DataTemplate DataType="vm:DiffContext">
              <v:DiffView/>
            </DataTemplate>
          </ContentControl.DataTemplates>
        </ContentControl>
      </Border>

      <Border Background="{DynamicResource Brush.Contents}"
              IsVisible="{Binding ActiveRevisionFileContent, Converter={x:Static ObjectConverters.IsNotNull}}">
        <Grid RowDefinitions="32,*">
          <Border Grid.Row="0" BorderBrush="{DynamicResource Brush.Border2}" BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="Auto,*,Auto" Margin="8,0,4,0">
              <Path Grid.Column="0" Width="13" Height="13" Data="{StaticResource Icons.File}"/>
              <TextBlock Grid.Column="1"
                         Margin="6,0,0,0"
                         VerticalAlignment="Center"
                         FontSize="11"
                         Text="{Binding ActiveRevisionFilePath}"
                         TextTrimming="CharacterEllipsis"/>
              <Button Grid.Column="2"
                      Classes="icon_button"
                      Width="26" Height="26"
                      Click="OnCloseRevisionFile"
                      ToolTip.Tip="Back to graph">
                <Path Width="10" Height="10" Data="{StaticResource Icons.Close}"/>
              </Button>
            </Grid>
          </Border>
          <v:RevisionFileContentViewer Grid.Row="1" Content="{Binding ActiveRevisionFileContent}"/>
        </Grid>
      </Border>
    </Grid>

    <GridSplitter Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3"
                  MinWidth="1" MinHeight="1"
                  HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                  Background="Transparent"
                  BorderBrush="{DynamicResource Brush.Border0}"
                  Focusable="False"
                  IsEnabled="{Binding #ThisControl.IsDetailsPanelExpanded, Mode=OneWay}"/>

    <Grid Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3" >
      <ContentControl Content="{Binding DetailContext, Mode=OneWay}">
        <ContentControl.DataTemplates>
          <DataTemplate DataType="m:Null">
            <TabControl Padding="0,4">
                <TabItem>
                  <TabItem.Header>
                    <Border Background="Transparent" PointerPressed="OnTabHeaderPointerPressed">
                      <TextBlock Classes="tab_header" Text="{DynamicResource Text.CommitDetail.Info}"/>
                    </Border>
                  </TabItem.Header>

                  <Grid IsVisible="{Binding #ThisControl.IsDetailsPanelExpanded, Mode=OneWay}">
                    <Path Width="128" Height="128"
                          Data="{StaticResource Icons.Detail}"
                          HorizontalAlignment="Center"
                          Fill="{DynamicResource Brush.FG2}"/>

                    <StackPanel Margin="0,8" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Bottom">
                      <Path Width="12" Height="12" VerticalAlignment="Center" Data="{StaticResource Icons.Info}" Fill="{DynamicResource Brush.FG2}"/>
                      <TextBlock Margin="4,0" Text="{DynamicResource Text.Histories.Tips.Prefix}" FontWeight="Bold" Foreground="{DynamicResource Brush.FG2}"/>
                      <TextBlock Text="{DynamicResource Text.Histories.Tips}" Foreground="{DynamicResource Brush.FG2}" IsVisible="{OnPlatform True, macOS=False}"/>
                      <TextBlock Text="{DynamicResource Text.Histories.Tips.MacOS}" Foreground="{DynamicResource Brush.FG2}" IsVisible="{OnPlatform False, macOS=True}"/>
                    </StackPanel>
                  </Grid>
                </TabItem>

                <TabItem IsEnabled="False">
                  <TabItem.Header>
                    <TextBlock Classes="tab_header" Text="{DynamicResource Text.CommitDetail.Changes}"/>
                  </TabItem.Header>
                </TabItem>

                <TabItem IsEnabled="False">
                  <TabItem.Header>
                    <TextBlock Classes="tab_header" Text="{DynamicResource Text.CommitDetail.Files}"/>
                  </TabItem.Header>
                </TabItem>
              </TabControl>
          </DataTemplate>

          <DataTemplate DataType="vm:CommitDetail">
            <v:CommitDetail IsDetailsPanelExpanded="{Binding #ThisControl.IsDetailsPanelExpanded, Mode=OneWay}"
                            UseExternalDiffHost="True"/>
          </DataTemplate>

          <DataTemplate DataType="vm:RevisionCompare">
            <TabControl SelectedIndex="1" Padding="0">
              <TabItem IsEnabled="False">
                <TabItem.Header>
                  <TextBlock Classes="tab_header" Text="{DynamicResource Text.CommitDetail.Info}"/>
                </TabItem.Header>
              </TabItem>

              <TabItem>
                <TabItem.Header>
                  <Border Background="Transparent" PointerPressed="OnTabHeaderPointerPressed">
                    <TextBlock Classes="tab_header" Text="{DynamicResource Text.CommitDetail.Changes}"/>
                  </Border>
                </TabItem.Header>

                <v:RevisionCompare IsVisible="{Binding #ThisControl.IsDetailsPanelExpanded, Mode=OneWay}"/>
              </TabItem>

              <TabItem IsEnabled="False">
                <TabItem.Header>
                  <TextBlock Classes="tab_header" Text="{DynamicResource Text.CommitDetail.Files}"/>
                </TabItem.Header>
              </TabItem>
            </TabControl>
          </DataTemplate>

          <DataTemplate DataType="m:Count">
            <TabControl Padding="0,4">
              <TabItem>
                <TabItem.Header>
                  <Border Background="Transparent" PointerPressed="OnTabHeaderPointerPressed">
                    <TextBlock Classes="tab_header" Text="{DynamicResource Text.CommitDetail.Info}"/>
                  </Border>
                </TabItem.Header>

                <StackPanel Orientation="Vertical"
                            HorizontalAlignment="Center" VerticalAlignment="Center"
                            IsVisible="{Binding #ThisControl.IsDetailsPanelExpanded, Mode=OneWay}">

                  <Path Width="128" Height="128"
                        Data="{StaticResource Icons.Detail}"
                        HorizontalAlignment="Center"
                        Fill="{DynamicResource Brush.FG2}"/>

                  <TextBlock HorizontalAlignment="Center"
                             Margin="0,16"
                             FontSize="24" FontWeight="Bold"
                             Foreground="{DynamicResource Brush.FG2}"
                             Text="{Binding Value, Converter={x:Static c:StringConverters.FormatByResourceKey}, ConverterParameter='Histories.Selected'}"/>
                </StackPanel>
              </TabItem>

              <TabItem IsEnabled="False">
                <TabItem.Header>
                  <TextBlock Classes="tab_header" Text="{DynamicResource Text.CommitDetail.Changes}"/>
                </TabItem.Header>
              </TabItem>

              <TabItem IsEnabled="False">
                <TabItem.Header>
                  <TextBlock Classes="tab_header" Text="{DynamicResource Text.CommitDetail.Files}"/>
                </TabItem.Header>
              </TabItem>
            </TabControl>
          </DataTemplate>
        </ContentControl.DataTemplates>
      </ContentControl>

      <StackPanel Orientation="Horizontal"
                  HorizontalAlignment="Right" VerticalAlignment="Top"
                  Margin="0,0,4,0">
        <Button Classes="icon_button"
                Width="28" Height="28"
                Padding="0"
                IsVisible="{Binding IsOpenAsStandaloneVisible, Mode=OneWay}"
                Click="OnOpenDetailsAsStandalone"
                HotKey="{OnPlatform Ctrl+N, macOS=⌘+N}">
          <ToolTip.Tip>
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
              <TextBlock Text="{DynamicResource Text.HistoriesDetailsStandalone}" VerticalAlignment="Center"/>
              <TextBlock Margin="16,0,0,0"
                         Text="{OnPlatform Ctrl+N, macOS=⌘+N}"
                         Foreground="{DynamicResource MenuFlyoutItemKeyboardAcceleratorTextForeground}"
                         FontSize="11"
                         VerticalAlignment="Center"/>
            </StackPanel>
          </ToolTip.Tip>
          <Path Width="15" Height="15" Margin="0,1,0,0" Data="{StaticResource Icons.OpenAsStandalone}"/>
        </Button>

        <ToggleButton Classes="line_path"
                      Width="28" Height="28"
                      Padding="0"
                      HotKey="{OnPlatform Ctrl+J, macOS=⌘+J}"
                      IsChecked="{Binding IsCollapseDetails, Mode=TwoWay}"
                      IsVisible="{Binding Source={x:Static vm:Preferences.Instance}, Path=UseTwoColumnsLayoutInHistories, Mode=OneWay, Converter={x:Static BoolConverters.Not}}">
          <ToolTip.Tip>
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
              <TextBlock Text="{DynamicResource Text.CommitDetail.CollapseToBottom}" VerticalAlignment="Center"/>
              <TextBlock Margin="16,0,0,0"
                         Text="{OnPlatform Ctrl+J, macOS=⌘+J}"
                         Foreground="{DynamicResource MenuFlyoutItemKeyboardAcceleratorTextForeground}"
                         FontSize="11"
                         VerticalAlignment="Center"/>
            </StackPanel>
          </ToolTip.Tip>
          <Path Width="14" Height="14" Data="{StaticResource Icons.CollapseToBottom}"/>
        </ToggleButton>
      </StackPanel>
    </Grid>
  </v:HistoriesLayout>
</UserControl>
