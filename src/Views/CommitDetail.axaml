<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:m="using:SourceGit.Models"
             xmlns:vm="using:SourceGit.ViewModels"
             xmlns:v="using:SourceGit.Views"
             xmlns:c="using:SourceGit.Converters"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="SourceGit.Views.CommitDetail"
             x:DataType="vm:CommitDetail"
             x:Name="ThisControl">
  <Grid>
  <Border Height="30"
                             Margin="6,4,6,0"
                             VerticalAlignment="Top"
                             Background="{DynamicResource Brush.Glass.Control}"
                             CornerRadius="8"
                             IsHitTestVisible="False"/>
  <Border Height="30"
          Margin="6,4,6,0"
          VerticalAlignment="Top"
          BorderBrush="{DynamicResource Brush.GlassBorder}"
          BorderThickness="1"
          CornerRadius="8"
          IsHitTestVisible="False"/>
  <TabControl Classes="inspector_tabs" SelectedIndex="{Binding ActiveTabIndex, Mode=TwoWay}">
    <!-- Information Page -->
    <TabItem Classes="inspector_tab">
      <TabItem.Header>
        <Border Background="Transparent" PointerPressed="OnTabHeaderPointerPressed" ToolTip.Tip="Commit details">
          <StackPanel Orientation="Horizontal" Spacing="6">
            <Path Classes="inspector_tab_icon" Width="12" Height="12" Data="{StaticResource Icons.Info}"/>
            <TextBlock Classes="tab_header" FontWeight="SemiBold" Text="{DynamicResource Text.CommitDetail.Info}"/>
          </StackPanel>
        </Border>
      </TabItem.Header>

      <ScrollViewer Margin="0"
                    Offset="{Binding ScrollOffset, Mode=TwoWay}"
                    HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto"
                    IsVisible="{Binding #ThisControl.IsDetailsPanelExpanded, Mode=OneWay}">
        <v:CommitBaseInfo Content="{Binding Commit}"
                          FullMessage="{Binding FullMessage}"
                          SignInfo="{Binding SignInfo}"
                          SupportsContainsIn="True"
                          WebLinks="{Binding WebLinks}"
                          Children="{Binding Children}"/>
      </ScrollViewer>
    </TabItem>

    <TabItem Classes="inspector_tab">
      <TabItem.Header>
        <Border Background="Transparent" PointerPressed="OnTabHeaderPointerPressed" ToolTip.Tip="Files changed by this commit">
          <StackPanel Orientation="Horizontal" Spacing="5">
            <Path Classes="inspector_tab_icon" Width="12" Height="12" Data="{StaticResource Icons.Diff}"/>
            <TextBlock Classes="tab_header" FontWeight="SemiBold" Text="{DynamicResource Text.CommitDetail.Changes}"/>
            <Border Classes="inspector_count_badge">
              <TextBlock FontSize="10" HorizontalAlignment="Center" Text="{Binding Changes.Count}"/>
            </Border>
          </StackPanel>
        </Border>
      </TabItem.Header>
      <v:CommitChanges Margin="0,4,0,0"
                       UseExternalDiffHost="{Binding #ThisControl.UseExternalDiffHost}"
                       IsVisible="{Binding #ThisControl.IsDetailsPanelExpanded, Mode=OneWay}"/>
    </TabItem>

    <TabItem Classes="inspector_tab">
      <TabItem.Header>
        <Border Background="Transparent" PointerPressed="OnTabHeaderPointerPressed" ToolTip.Tip="Complete repository at this commit">
          <StackPanel Orientation="Horizontal" Spacing="6">
            <Path Classes="inspector_tab_icon" Width="12" Height="12" Data="{StaticResource Icons.Tree}"/>
            <TextBlock Classes="tab_header" FontWeight="SemiBold" Text="{DynamicResource Text.CommitDetail.Files}"/>
          </StackPanel>
        </Border>
      </TabItem.Header>
      <v:RevisionFiles Margin="0,4,0,0"
                       UseExternalFileHost="{Binding #ThisControl.UseExternalDiffHost}"
                       IsVisible="{Binding #ThisControl.IsDetailsPanelExpanded, Mode=OneWay}"/>
    </TabItem>
  </TabControl>
  </Grid>
</UserControl>
